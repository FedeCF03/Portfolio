@page "/notes/{Slug}"
@inject FedePortfolio.Web.Services.INotesService Notes
@inject FedePortfolio.Web.Services.SiteMetadata Meta
@inject NavigationManager Nav

<PageTitle>@(note?.Title ?? "Nota") — @Meta.Name</PageTitle>

@if (note is null)
{
  <section class="note-missing">
    <h1>Nota no encontrada</h1>
    <p>La nota que buscás no existe o fue movida.</p>
    <p><a href="/notes">Volver al listado</a></p>
  </section>
}
else
{
  <article class="note">
    <header class="note__header">
      <p class="note__back"><a href="/notes">← Notas</a></p>
      <h1 class="note__title">@note.Title</h1>
      <p class="note__meta">
        <time datetime="@note.IsoDate">@note.FormattedDate</time>
        @if (note.Tags.Count > 0)
        {
          <span aria-hidden="true">·</span>
          <span class="note__tags">
            @foreach (var tag in note.Tags)
            {
              <span class="tag">@tag</span>
            }
          </span>
        }
      </p>
    </header>
    <hr />
    <div class="note__body prose">
      @((MarkupString)note.HtmlContent)
    </div>
  </article>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    private FedePortfolio.Web.Models.Note? note;

    protected override void OnParametersSet()
    {
        note = Notes.GetBySlug(Slug);
        if (note is null)
        {
            // Soft 404 handled by rendering a friendly message in the page itself
        }
    }
}
