@page "/error"
@inject FedePortfolio.Web.Services.SiteMetadata Meta

<PageTitle>Error — @Meta.Name</PageTitle>

<section class="error-page">
  <p class="error-page__code">500</p>
  <h1>Algo salió mal</h1>
  <p>Hubo un error procesando tu solicitud. Probá recargar la página.</p>
  <p><a href="/">Volver al inicio</a></p>
</section>
