@page "/notes"
@inject FedePortfolio.Web.Services.INotesService NotesSvc
@inject FedePortfolio.Web.Services.SiteMetadata Meta

<PageTitle>Notas — @Meta.Name</PageTitle>

<header class="notes-header">
  <h1>Notas</h1>
  <p class="notes-header__lead">
    Apuntes cronológicos sobre redes, infraestructura, sistemas distribuidos y herramientas que voy construyendo.
  </p>
</header>

@if (notes.Count == 0)
{
  <p class="state">Todavía no hay notas publicadas.</p>
}
else
{
  <ol class="notes-list" reversed>
    @foreach (var note in notes)
    {
      <li class="note-item">
        <a class="note-item__link" href="/notes/@note.Slug">
          <span class="note-item__date">@note.FormattedDate</span>
          <span class="note-item__title">@note.Title</span>
          @if (note.Tags.Count > 0)
          {
            <span class="note-item__tags">
              @foreach (var tag in note.Tags)
              {
                <span class="tag">@tag</span>
              }
            </span>
          }
        </a>
      </li>
    }
  </ol>
}

@code {
    private IReadOnlyList<FedePortfolio.Web.Models.Note> notes = Array.Empty<FedePortfolio.Web.Models.Note>();

    protected override void OnInitialized()
    {
        notes = NotesSvc.GetAll();
    }
}
